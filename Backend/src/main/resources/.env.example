# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

# JWT
SECRET_KEY=your_256bit_hex_jwt_secret_key

# Database
SPRING_DATASOURCE_PASSWORD=your_db_password
# Development: update | Staging: update | Production: validate
DDL_AUTO=update

# Mail (Gmail: use App Password from https://myaccount.google.com/apppasswords)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_DEBUG=false

# MJML (https://mjml.io/api)
MJML_APP_ID=your_mjml_app_id
MJML_APP_KEY=your_mjml_app_key

# CORS / URLs
ALLOWED_ORIGIN=http://localhost:3000
APP_FRONTEND_URL=http://localhost:3000

# reCAPTCHA (https://www.google.com/recaptcha/admin)
RECAPTCHA_SECRET=your_recaptcha_secret_key
